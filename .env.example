# Paradigm LLM — copiar a .env y ajustar
# cp .env.example .env

# Proveedor: ollama | groq | openai | grok | disabled
PARADIGM_LLM_PROVIDER=ollama
PARADIGM_LLM_MODEL=llama3.2
PARADIGM_EMBEDDING_MODEL=nomic-embed-text
PARADIGM_LLM_TEMPERATURE=0.1
PARADIGM_LLM_MAX_TOKENS=2048

# Ollama (default — sin API key)
OLLAMA_BASE_URL=http://localhost:11434

# RAG
PARADIGM_RAG_ENABLED=true
PARADIGM_RAG_TOP_K=5
# PARADIGM_RAG_PERSIST_DIR=data/processed/rag_index

# Logging de interacciones LLM (Fase 5)
PARADIGM_LLM_LOG_INTERACTIONS=true

# Rate limit — consultas LLM por minuto (default 10)
PARADIGM_LLM_RATE_LIMIT=10

# Sidebar: mostrar historial AI al iniciar (modo debug)
# PARADIGM_DEBUG=true

# --- Alternativas cloud (descomentar y cambiar PARADIGM_LLM_PROVIDER) ---

# Groq — https://console.groq.com
# PARADIGM_LLM_PROVIDER=groq
# PARADIGM_LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=

# OpenAI — https://platform.openai.com
# PARADIGM_LLM_PROVIDER=openai
# PARADIGM_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Grok (xAI) — API compatible OpenAI
# PARADIGM_LLM_PROVIDER=grok
# PARADIGM_LLM_MODEL=grok-2-latest
# GROK_API_KEY=
# GROK_BASE_URL=https://api.x.ai/v1

# Sin LLM — solo motor heurístico determinístico
# PARADIGM_LLM_PROVIDER=disabled
